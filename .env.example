# OpenAI API Key (optional - dummy output is used when not set)
OPENAI_API_KEY=sk-your-api-key-here

# v5 Feature Flags
ENABLE_REMOTE_REVIEW=true
ENABLE_PRIMARY_PORTAL=true
ENABLE_SPECIALTY_REROUTE=false
OPENAI_MODEL_STRUCTURING=gpt-4o-mini
OPENAI_MODEL_SUMMARY=gpt-4o-mini
TRIAGE_REVIEW_THRESHOLD=YELLOW
RED_FLAG_STRICT_MODE=true
